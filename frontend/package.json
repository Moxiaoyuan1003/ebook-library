{
  "name": "ebook-library-frontend",
  "version": "0.1.0",
  "description": "个人图书管理 - 支持多种电子书格式的桌面图书管理应用",
  "homepage": "https://github.com/Moxiaoyuan1003/ebook-library",
  "author": {
    "name": "Moxiaoyuan1003",
    "email": "moxiaoyuan1003@users.noreply.github.com"
  },
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "tsc --project tsconfig.electron.json && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc --project tsconfig.electron.json && vite build && electron-builder --config electron-builder.yml",
    "electron:build:win": "tsc --project tsconfig.electron.json && vite build && electron-builder --win --config electron-builder.yml",
    "electron:build:mac": "tsc --project tsconfig.electron.json && vite build && electron-builder --mac --config electron-builder.yml",
    "electron:build:linux": "tsc --project tsconfig.electron.json && vite build && electron-builder --linux --config electron-builder.yml",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "antd": "^5.20.0",
    "axios": "^1.7.0",
    "electron-updater": "^6.8.3",
    "epubjs": "^0.3.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-pdf": "^9.1.0",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.3.0",
    "axios-mock-adapter": "^2.1.0",
    "concurrently": "^8.2.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "wait-on": "^7.2.0"
  }
}
